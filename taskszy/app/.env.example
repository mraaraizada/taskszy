# ─────────────────────────────────────────────────────────────────────────────
# Taskzy — Root App Environment Variables
# Copy this file to .env.local for local development.
# In production, set these in your Vercel project → Settings → Environment Variables.
# NEVER commit .env.local or .env.production to git.
# ─────────────────────────────────────────────────────────────────────────────

# Firebase — get these from Firebase Console → Project Settings → Your Apps → Web
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id

# Cloudflare Turnstile — get these from Cloudflare Dashboard → Turnstile
# Get your site key from: https://dash.cloudflare.com/?to=/:account/turnstile
VITE_TURNSTILE_SITE_KEY=your_turnstile_site_key_here

# Razorpay — get these from Razorpay Dashboard → Settings → API Keys
# For local development, use test keys (rzp_test_...)
# For production, use live keys (rzp_live_...) after website verification
VITE_RAZORPAY_KEY_ID=rzp_live_SwQkTJ7VdTAUhE
VITE_RAZORPAY_KEY_SECRET=c2Ot2dlkie0wDWlem2OHc1qO

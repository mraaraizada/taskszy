{
  "name": "taskszy-website",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "Taskszy - Marketing Website & Landing Page",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "proxy": "node local-proxy.js",
    "dev:app": "cd app && npm run dev",
    "dev:admin": "cd adminzdashboard && npm run dev",
    "clean": "node clean-build.js",
    "build:all": "npm run clean && npm run build && cd app && npm install && npm run build && cd ../adminzdashboard && npm install && npm run build",
    "deploy:merge": "mkdir -p build && cp -r dist/* build/ && mkdir -p build/app && cp -r app/dist/* build/app/ && mkdir -p build/adminzdashboard && cp -r adminzdashboard/dist/* build/adminzdashboard/",
    "build:cloudflare": "npm run clean && node build-for-cloudflare.js",
    "verify:seo": "node verify-seo.js",
    "generate:sitemap": "node generate-sitemap.js"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@number-flow/react": "^0.6.0",
    "@paper-design/shaders-react": "^0.0.76",
    "@radix-ui/react-tabs": "^1.1.13",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@rive-app/react-canvas": "^4.28.4",
    "@splinetool/react-spline": "^4.1.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dicons": "^1.1.7",
    "firebase": "^10.14.1",
    "framer-motion": "^11.18.2",
    "gsap": "^3.15.0",
    "http-proxy": "^1.18.1",
    "lottie-react": "^2.4.1",
    "lucide-react": "^0.441.0",
    "motion": "^12.38.0",
    "ogl": "^1.0.11",
    "postprocessing": "^6.39.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-helmet-async": "^2.0.5",
    "react-router-dom": "^6.30.4",
    "react-use-measure": "^2.1.7",
    "tailwind-merge": "^3.5.0",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.45",
    "tailwindcss": "^3.4.10",
    "tailwindcss-animate": "^1.0.7",
    "terser": "^5.48.0",
    "vite": "^5.4.2"
  }
}
